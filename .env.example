APP_ENV=production
APP_PORT=8080
POSTGRES_DB=beezaoffice
POSTGRES_USER=beeza
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+psycopg://beeza:change-this-password@postgres:5432/beezaoffice
REDIS_URL=redis://redis:6379/0
BEEZA_AUTH_TOKEN=change-this-to-a-long-random-token

# Server-side runtime synchronization
BEEZA_RUNTIME_SYNC_ENABLED=true
BEEZA_RUNTIME_SYNC_INTERVAL_SECONDS=5
BEEZA_RUNTIME_SYNC_BATCH_SIZE=100
BEEZA_RUNTIME_SYNC_CONCURRENCY=8

# Cross-runtime collaboration bus
BEEZA_COLLAB_ENABLED=true
BEEZA_COLLAB_INTERVAL_SECONDS=3
BEEZA_COLLAB_BATCH_SIZE=100
BEEZA_COLLAB_FOLLOW_UP_SECONDS=300
BEEZA_COLLAB_MAX_FOLLOW_UPS=2

# External runtimes. Leave blank to keep a connector unconfigured.
OPENCLAW_BASE_URL=
OPENCLAW_AUTH_TOKEN=
OPENCLAW_AGENT_TARGET=openclaw/default

CHERRYAGENT_BASE_URL=
CHERRYAGENT_AUTH_TOKEN=

HERMES_BASE_URL=
HERMES_AUTH_TOKEN=
HERMES_MODEL=hermes-agent

THCLAW_BASE_URL=
THCLAW_AUTH_TOKEN=
THCLAW_MODEL=
THCLAW_WORKSPACE_DIR=
