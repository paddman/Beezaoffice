APP_ENV=production
APP_PORT=8080
POSTGRES_DB=beezaoffice
POSTGRES_USER=beeza
POSTGRES_PASSWORD=SET_A_STRONG_PASSWORD
DATABASE_URL=postgresql+psycopg://beeza:SET_A_STRONG_PASSWORD@postgres:5432/beezaoffice
REDIS_URL=redis://redis:6379/0
BEEZA_AUTH_TOKEN=SET_A_LONG_RANDOM_TOKEN

# Governance and identity
BEEZA_GOVERNANCE_ENFORCED=true
BEEZA_DEFAULT_IDENTITY=human:owner
BEEZA_APPROVAL_TTL_MINUTES=60

# Runtime event worker
BEEZA_RUNTIME_SYNC_ENABLED=true
BEEZA_RUNTIME_SYNC_INTERVAL_SECONDS=5
BEEZA_RUNTIME_SYNC_BATCH_SIZE=100
BEEZA_RUNTIME_SYNC_CONCURRENCY=8

# Collaboration worker
BEEZA_COLLAB_ENABLED=true
BEEZA_COLLAB_INTERVAL_SECONDS=3
BEEZA_COLLAB_BATCH_SIZE=100
BEEZA_COLLAB_FOLLOW_UP_SECONDS=300
BEEZA_COLLAB_MAX_FOLLOW_UPS=2

# Meeting worker
BEEZA_MEETING_ENABLED=true
BEEZA_MEETING_INTERVAL_SECONDS=3
BEEZA_MEETING_BATCH_SIZE=50
BEEZA_MEETING_TURN_TIMEOUT_SECONDS=900

OPENCLAW_BASE_URL=
OPENCLAW_AUTH_TOKEN=
OPENCLAW_AGENT_TARGET=openclaw/default

CHERRYAGENT_BASE_URL=
CHERRYAGENT_AUTH_TOKEN=

HERMES_BASE_URL=
HERMES_AUTH_TOKEN=
HERMES_MODEL=hermes-agent

THCLAW_BASE_URL=
THCLAW_AUTH_TOKEN=
THCLAW_MODEL=
THCLAW_WORKSPACE_DIR=
