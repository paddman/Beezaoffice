APP_ENV=production
APP_PORT=8080
POSTGRES_DB=beezaoffice
POSTGRES_USER=beeza
POSTGRES_PASSWORD=SET_A_STRONG_PASSWORD
DATABASE_URL=postgresql+psycopg://beeza:SET_A_STRONG_PASSWORD@postgres:5432/beezaoffice
REDIS_URL=redis://redis:6379/0
BEEZA_AUTH_TOKEN=SET_A_LONG_RANDOM_TOKEN
BEEZA_PUBLIC_URL=http://localhost:8080

# Enterprise tenant and sovereign deployment
BEEZA_DEFAULT_TENANT=tenant:beeza
BEEZA_OBJECT_STORE_ENDPOINT=http://minio:9000
BEEZA_OBJECT_STORE_BUCKET=beeza-evidence
BEEZA_OBJECT_STORE_REGION=on-premises
BEEZA_BACKUP_BUCKET=beeza-backups
BEEZA_BACKUP_ENCRYPTION_KEY_REF=
BEEZA_AIR_GAPPED=false
BEEZA_SIEM_EXPORT_URL=

# Governance and identity
BEEZA_GOVERNANCE_ENFORCED=true
BEEZA_DEFAULT_IDENTITY=human:owner
BEEZA_APPROVAL_TTL_MINUTES=60

# Executive and business layer
BEEZA_BUSINESS_ENABLED=true
BEEZA_BUSINESS_INTERVAL_SECONDS=60
BEEZA_DEFAULT_LABOR_RATE_USD=30
BEEZA_BILLING_CURRENCY=USD

# Runtime event worker
BEEZA_RUNTIME_SYNC_ENABLED=true
BEEZA_RUNTIME_SYNC_INTERVAL_SECONDS=5
BEEZA_RUNTIME_SYNC_BATCH_SIZE=100
BEEZA_RUNTIME_SYNC_CONCURRENCY=8

# Collaboration worker
BEEZA_COLLAB_ENABLED=true
BEEZA_COLLAB_INTERVAL_SECONDS=3
BEEZA_COLLAB_BATCH_SIZE=100
BEEZA_COLLAB_FOLLOW_UP_SECONDS=300
BEEZA_COLLAB_MAX_FOLLOW_UPS=2

# Meeting worker
BEEZA_MEETING_ENABLED=true
BEEZA_MEETING_INTERVAL_SECONDS=3
BEEZA_MEETING_BATCH_SIZE=50
BEEZA_MEETING_TURN_TIMEOUT_SECONDS=900

# Intelligent scheduler and failover router
BEEZA_SCHEDULER_ENABLED=true
BEEZA_SCHEDULER_INTERVAL_SECONDS=3
BEEZA_SCHEDULER_BATCH_SIZE=100
BEEZA_SCHEDULER_FAILOVER_ATTEMPTS=3

# Evaluation worker
BEEZA_EVALUATOR_ENABLED=true
BEEZA_EVALUATOR_INTERVAL_SECONDS=10
BEEZA_EVALUATOR_BATCH_SIZE=100

# SOP worker
BEEZA_SOP_ENABLED=true
BEEZA_SOP_INTERVAL_SECONDS=3
BEEZA_SOP_BATCH_SIZE=100

# Protocol gateway
BEEZA_PROTOCOL_ENABLED=true
BEEZA_PROTOCOL_INTERVAL_SECONDS=2
BEEZA_PROTOCOL_BATCH_SIZE=100
BEEZA_PROTOCOL_SYNC_TIMEOUT_SECONDS=20
BEEZA_MCP_ALLOWED_ORIGINS=
BEEZA_WEBHOOK_SECRET=

OPENCLAW_BASE_URL=
OPENCLAW_AUTH_TOKEN=
OPENCLAW_AGENT_TARGET=openclaw/default

CHERRYAGENT_BASE_URL=
CHERRYAGENT_AUTH_TOKEN=

HERMES_BASE_URL=
HERMES_AUTH_TOKEN=
HERMES_MODEL=hermes-agent

THCLAW_BASE_URL=
THCLAW_AUTH_TOKEN=
THCLAW_MODEL=
THCLAW_WORKSPACE_DIR=
